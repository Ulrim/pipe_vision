# ===== AIVIS .gitignore =====

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg
*.egg-info/
.eggs/
build/
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.hypothesis/

# ---------- Node / Frontend ----------
node_modules/
dist/
dist-ssr/
build/
.cache/
.vite/
*.local
.eslintcache
.turbo/
coverage/
*.tsbuildinfo
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Environment / Secrets ----------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ---------- Data / Images / Datasets ----------
dataset/
datasets/
data/
review/
*.db
*.sqlite
*.sqlite3
# raw / result inspection images (operational, never committed)
images/
raw/
result/

# ---------- MinIO / Postgres local volumes ----------
minio-data/
minio_data/
postgres-data/
postgres_data/
pgdata/

# ---------- Docker ----------
*.tar
docker-compose.override.yml

# ---------- ML model artifacts ----------
*.onnx
*.pt
*.pth
*.engine
*.weights

# ---------- OS / Editor ----------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.log
