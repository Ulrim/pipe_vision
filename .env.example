# ===== AIVIS environment example =====
# Copy to .env and adjust for your site. Never commit the real .env.
# cp .env.example .env

# ---------- PostgreSQL ----------
POSTGRES_USER=aivis
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=aivis
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full SQLAlchemy / asyncpg URL used by the api service.
# Host "postgres" resolves to the compose service name on the internal network.
DATABASE_URL=postgresql+psycopg://aivis:change-me-in-production@postgres:5432/aivis

# ---------- MinIO (S3-compatible object storage) ----------
MINIO_ROOT_USER=aivis-minio
MINIO_ROOT_PASSWORD=change-me-in-production
# Endpoint used by the api/vision services on the internal network.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=aivis-minio
MINIO_SECRET_KEY=change-me-in-production
MINIO_USE_SSL=false
# Buckets for raw originals, judged overlays, and review (false-positive/miss) images.
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_RESULT=result
MINIO_BUCKET_REVIEW=review

# ---------- Vision / Hardware Abstraction (services/vision) ----------
# sim = SimulatorCamera (replays AIVIS_DATASET_DIR). genicam = real industrial camera.
AIVIS_CAMERA=sim
# Folder the SimulatorCamera replays frame-by-frame (mounted into the vision container).
AIVIS_DATASET_DIR=/data/dataset
# Shared local image store on the "images" volume mounted into both vision and api.
# Vision writes inspection JPEGs, api reads & serves them — they MUST agree on this path.
# Layout under this dir: raw/ (originals), result/ (judged overlays), review/ (FP/miss).
AIVIS_IMAGES_DIR=/data/images
# Internal URL the vision worker uses to POST inspection results to the api.
# MUST include the scheme (http://). The worker uses this value directly as the
# HTTP base — it does not prepend a scheme. On Render set http://aivis-api:8000.
AIVIS_API_URL=http://api:8000
# Item code the worker inspects (FK target item_master.item_code; demo = HP12).
AIVIS_ITEM_CODE=HP12
# Cadence between simulator triggers (ms). Lower = faster demo throughput.
AIVIS_WORKER_INTERVAL_MS=1500

# Trigger source: timer (sim default) | filewatch | dio (digital IO) | mqtt.
AIVIS_TRIGGER=timer
# ONNX execution providers (CPU default). GPU override sets cuda (docker-compose.gpu.yml).
# AIVIS_ONNX_PROVIDERS=CPUExecutionProvider
# Optional surface model ONNX path (falls back to classic CV when unset, §6.3).
# AIVIS_SURFACE_ONNX=/data/models/surface.onnx

# -- genicam camera (only when AIVIS_CAMERA=genicam, P7 real-camera integration) --
# AIVIS_GENICAM_BACKEND=harvesters
# AIVIS_GENICAM_CTI=/opt/mvIMPACT/lib/x86_64/mvGenTLProducer.cti
# AIVIS_GENICAM_DEVICE=
# AIVIS_GENICAM_TIMEOUT_MS=2000
# -- dio / mqtt trigger (only for AIVIS_TRIGGER=dio|mqtt) --
# AIVIS_DIO_DRIVER=
# AIVIS_DIO_CHANNEL=
# AIVIS_MQTT_HOST=localhost
# AIVIS_MQTT_PORT=1883
# AIVIS_MQTT_TRIGGER_TOPIC=aivis/trigger

# Internal service token for POST /inspection (M14). Unset = whitelist (no-auth)
# on the single-host topology. Set a value to require X-Service-Token on the
# vision -> api internal call (configure the same value on the api service).
# AIVIS_SERVICE_TOKEN=

# ---------- Auth (services/api, RBAC: operator / quality / admin) ----------
# JWT signing secret for the api. MUST be a long random string in production.
JWT_SECRET=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# Initial admin account seeded on first startup. CHANGE THE PASSWORD on the site PC.
AIVIS_SEED_ON_STARTUP=true
AIVIS_SEED_ADMIN_USER=admin
AIVIS_SEED_ADMIN_PASSWORD=change-me-admin-password
# Seed a demo item (HP12) on startup so the vision worker's FK target exists
# without manual master setup. true is recommended for the cloud demo.
AIVIS_SEED_DEMO_ITEM=false
AIVIS_DEMO_ITEM_CODE=HP12

# ---------- CORS (browser origins allowed to call the api) ----------
# Comma-separated list of allowed origins. Unset = "*" (dev convenience only).
# For the cloud demo set this to the two Vercel domains (no trailing slash), e.g.
# ALLOWED_ORIGINS=https://aivis-hmi.vercel.app,https://aivis-dashboard.vercel.app
# ALLOWED_ORIGINS=
# Local backup queue dir for inspection results when the DB write fails (M7 DoD).
# AIVIS_LOCAL_QUEUE_DIR=/app/local_queue
# Consecutive-NG alarm threshold per cam_id (M6). Fires consecutive_ng over /ws/live.
AIVIS_CONSEC_NG_THRESHOLD=3

# ---------- MES integration (§7.3) ----------
# table = DB interface table (preferred / most stable). rest = POST /mes/quality.
MES_MODE=table
# REST mode endpoint (only when MES_MODE=rest). Unset = fake transport (dev).
# MES_REST_URL=http://mes-host:port/quality
# MES_REST_TIMEOUT_S=5
# MES_IDEM_HEADER=X-Idempotency-Key
# Watchdog re-sends mes_synced=false rows for 100% link rate.
MES_WATCHDOG_INTERVAL_S=10
MES_WATCHDOG_BATCH=100
MES_MAX_RETRY=8
MES_BACKOFF_BASE_S=0.5
MES_BACKOFF_MAX_S=30

# ---------- Logging ----------
LOG_LEVEL=INFO
