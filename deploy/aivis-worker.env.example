# ===== AIVIS Pi 검사 워커 환경변수 (EnvironmentFile 템플릿) =====
# 배치:  sudo install -D -m600 deploy/aivis-worker.env.example /etc/aivis/worker.env
# 이후 /etc/aivis/worker.env 를 현장 값으로 수정한다. 이 파일은 systemd 가 읽으므로
# 셸 문법(export/따옴표 확장)이 아니라 KEY=VALUE 한 줄 형식만 쓴다(주석은 # 로).
# 자세한 설명: docs/RASPBERRY_PI.md

# ---------- 카메라 (HAL) ----------
# picam = PiCameraAdapter(picamera2/IMX708). 이 값 하나만으로 워커가 Pi 카메라로
# 동작한다(create_camera() 팩토리가 어댑터를 선택; 애플리케이션 코드 변경 없음).
# 개발/무카메라 검증은 sim(SimulatorCamera).
AIVIS_CAMERA=picam

# 캡처 해상도(가로x세로). PiCameraAdapter 가 읽는다. IMX708 권장:
#   2304x1296 (기본, 2x2 binning · 빠름 · 300ms 예산 유리)
#   4608x2592 (풀 해상도 · 미세 결함/정밀 계측 · CPU 부하↑)
# 미설정 시 어댑터 기본값. 최종 값은 item_master.capture_recipe(width/height)가
# 우선할 수 있다(품목별 촬영 레시피).
AIVIS_PICAM_SIZE=2304x1296

# 색상(빨강/파랑) 뒤바뀜 보정. HMI 미리보기가 푸르스름/불그스름하면 true 로.
# (picamera2 RGB ↔ OpenCV BGR 채널 순서 이슈 발생 시에만 사용)
AIVIS_PICAM_SWAP_RB=false

# start 직후 버릴 워밍업 프레임 수(AE/AWB 수렴 대기). 기본 2. 첫 프레임이 어둡거나
# 색이 튀면 늘린다(처리량과 트레이드오프).
# AIVIS_PICAM_WARMUP_FRAMES=2

# ---------- 검사 대상 / 식별 ----------
# 품목 코드(FK: item_master.item_code). 워커가 이 품목의 기준길이/공차/임계값/
# capture_recipe 를 GET /master/items 로 가져와 카메라를 configure 한다.
AIVIS_ITEM_CODE=HP12
# 카메라 식별자(다중 스테이션 구분). 검사행 cam_id 로 저장된다.
AIVIS_CAM_ID=PI-CAM1
# LOT / 교대 / 작업자(선택). 미설정 시 LOT 는 당일 날짜로 자동 생성.
# AIVIS_LOT=LOT20260703
# AIVIS_SHIFT=A
# AIVIS_OPERATOR=

# 실 라인 트리거 간격(ms). 실물 트리거(디지털 IO/센서) 결선 전까지 타이머 캡처
# 주기로 사용. 300ms 처리예산을 고려해 여유 있게(캡처+추론+POST > interval 금지).
AIVIS_WORKER_INTERVAL_MS=1500

# ---------- 오프라인 스풀 (전송 실패분 디스크 버퍼 → 복구 시 자동 재전송) ----------
# 인터넷 단절 중 검사결과(수치+이미지)를 이 폴더에 보관했다가 API 복구 시
# 오래된 것부터 재전송한다. 서버가 자연키(cam_id+시각+lot+품목) 멱등이라 중복 없음.
AIVIS_SPOOL_DIR=/var/lib/aivis/spool
# 스풀 총 용량 상한(MB). 초과 시 가장 오래된 항목부터 삭제(SD 카드 보호).
AIVIS_SPOOL_MAX_MB=512
# 루프당 재전송 최대 건수(라이브 검사를 굶기지 않도록 소량씩).
# AIVIS_SPOOL_FLUSH_BATCH=20

# ==========================================================================
# 배포 모드 A — 엣지→클라우드 (권장): Pi 는 워커만, 결과는 클라우드 api 로 POST
# ==========================================================================
# 이미 구축한 스택 재사용: api=Render(FastAPI), DB/Storage=Supabase, 프론트=Vercel.
# 이미지는 워커가 Supabase Storage 로 업로드(api 가 프록시 서빙) → 로컬 디스크 불필요.
AIVIS_API_URL=https://aivis-api.onrender.com
# POST /inspection 보호용 내부 토큰(api 와 동일 값). 클라우드에서는 반드시 설정.
AIVIS_SERVICE_TOKEN=change-me-service-token
# 스토리지 백엔드: supabase(클라우드) — 아래 SUPABASE_* 를 채운다.
AIVIS_STORAGE_BACKEND=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me-supabase-service-role-secret
SUPABASE_STORAGE_BUCKET=inspection-images

# ==========================================================================
# 배포 모드 B — 독립형(오프라인): Pi 1대에서 api(sqlite)+워커+HMI 를 함께 구동
# ==========================================================================
# 아래를 대신 사용한다(모드 A 의 클라우드 값들은 주석 처리).
#   AIVIS_API_URL=http://127.0.0.1:8000        # 같은 Pi 의 로컬 api(uvicorn)
#   AIVIS_SERVICE_TOKEN=                        # 단일호스트는 미설정(화이트리스트) 가능
#   AIVIS_STORAGE_BACKEND=local                 # 이미지를 로컬 디스크에 저장
#   AIVIS_IMAGES_DIR=/var/lib/aivis/images      # api 와 반드시 동일 경로(raw/result/review)
# 이 경우 api 는 DATABASE_URL 미설정 → sqlite(./aivis_dev.db) 자동 사용.

# ---------- 서비스 계정 폴백(GET /master 인증용) ----------
# 토큰이 없을 때 워커가 기준정보 조회를 위해 로그인하는 시드 계정. api 시드값과 일치.
AIVIS_SEED_ADMIN_USER=admin
# AIVIS_SEED_ADMIN_PASSWORD=change-me-admin-password

# ---------- 표면 ONNX(선택) ----------
# 미설정 시 고전 CV 폴백으로 동작(§6.3). Pi 4 는 경량/INT8 모델 권장.
# AIVIS_SURFACE_ONNX=/var/lib/aivis/models/surface.onnx
# AIVIS_ONNX_PROVIDERS=CPUExecutionProvider

# ---------- 로깅 ----------
LOG_LEVEL=INFO
